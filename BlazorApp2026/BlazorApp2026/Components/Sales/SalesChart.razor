@page "/sales"
@using Blazor26.Models.Models
@using Syncfusion.Blazor.Charts
@using Syncfusion.Blazor
@inject IUnitOfWork _unitOfWork
@rendermode InteractiveServer



<SfChart Title="Sales of products this year">
    <ChartPrimaryXAxis Title="Month" ValueType="Syncfusion.Blazor.Charts.ValueType.Category"></ChartPrimaryXAxis>
    <ChartPrimaryYAxis Title="Amount Sold"></ChartPrimaryYAxis>
    <ChartLegendSettings Visible="true"></ChartLegendSettings>
    <ChartSeriesCollection>
        <ChartSeries DataSource="@listOfSales" XName="MonthName" YName="SalesAmount" Type="ChartSeriesType.Column">
        </ChartSeries>
    </ChartSeriesCollection>
</SfChart>

@code {
    private IEnumerable<Sales> listOfSales { get; set; } = new List<Sales>();
    private bool isLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        await Task.Run(LoadSales);

    }

    private void LoadSales()
    {
        listOfSales = _unitOfWork.SalesRepo.GetAll();
        isLoading = false;
    }
}

